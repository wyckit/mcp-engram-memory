<Project>
    <PropertyGroup>
        <BgeMicroModelCacheDir Condition="'$(BgeMicroModelCacheDir)' == ''">$(MSBuildThisFileDirectory)..\.cache\</BgeMicroModelCacheDir>
        <BgeMicroModelUrl Condition="'$(BgeMicroModelUrl)' == ''">https://huggingface.co/SmartComponents/bge-micro-v2/resolve/72908b7/onnx/model_quantized.onnx</BgeMicroModelUrl>
        <BgeMicroVocabUrl Condition="'$(BgeMicroVocabUrl)' == ''">https://huggingface.co/SmartComponents/bge-micro-v2/resolve/72908b7/vocab.txt</BgeMicroVocabUrl>
        <BgeMicroModelPath Condition="'$(BgeMicroModelPath)' == ''">$(BgeMicroModelCacheDir)$([System.Text.RegularExpressions.Regex]::Replace($(BgeMicroModelUrl), "[^a-zA-Z0-9\.]", "_"))</BgeMicroModelPath>
        <BgeMicroVocabPath Condition="'$(BgeMicroVocabPath)' == ''">$(BgeMicroModelCacheDir)$([System.Text.RegularExpressions.Regex]::Replace($(BgeMicroVocabUrl), "[^a-zA-Z0-9\.]", "_"))</BgeMicroVocabPath>
    </PropertyGroup>

    <Target Name="AttachBgeMicroModelFiles" BeforeTargets="AssignTargetPaths" DependsOnTargets="AcquireBgeMicroModel; AcquireBgeMicroVocab">
        <ItemGroup>
            <Content CopyToOutputDirectory="PreserveNewest" Pack="true"
                     Include="$(BgeMicroModelPath)"
                     TargetPath="LocalEmbeddingsModel\default\model.onnx" />
            <Content CopyToOutputDirectory="PreserveNewest" Pack="true"
                     Include="$(BgeMicroVocabPath)"
                     TargetPath="LocalEmbeddingsModel\default\vocab.txt" />
        </ItemGroup>
    </Target>

    <!--
      Parallel-TFM safety: when a project multi-targets (e.g. net8.0;net9.0;net10.0),
      MSBuild fans out one inner build per TFM in parallel. Each inner build invokes
      these targets, all see the cache missing, all download to their own temp file,
      then race at the Move. Without mitigation, N-1 racers fail with MSB3677.

      Mitigation: ContinueOnError="WarnAndContinue" on the Move so a losing racer
      emits a warning and proceeds; Delete cleans any leftover temp file. Since every
      downloader writes the same bytes (deterministic URL + hash), last-writer-wins
      is semantically safe. The winner leaves a valid cache; the losers no-op.
    -->
    <Target Name="AcquireBgeMicroModel" Condition="!Exists('$(BgeMicroModelPath)')">
        <MakeDir Directories="$(BgeMicroModelCacheDir)" />
        <PropertyGroup>
            <_TempFilePath>$([System.IO.Path]::GetTempFileName())</_TempFilePath>
        </PropertyGroup>
        <DownloadFile SourceUrl="$(BgeMicroModelUrl)"
                      DestinationFolder="$([System.IO.Path]::GetDirectoryName($(_TempFilePath)))"
                      DestinationFileName="$([System.IO.Path]::GetFileName($(_TempFilePath)))" />
        <Move SourceFiles="$(_TempFilePath)" DestinationFiles="$(BgeMicroModelPath)"
              ContinueOnError="WarnAndContinue"
              Condition="!Exists('$(BgeMicroModelPath)')" />
        <Delete Files="$(_TempFilePath)" Condition="Exists('$(_TempFilePath)')" />
    </Target>

    <Target Name="AcquireBgeMicroVocab" Condition="!Exists('$(BgeMicroVocabPath)')">
        <MakeDir Directories="$(BgeMicroModelCacheDir)" />
        <PropertyGroup>
            <_TempFilePath>$([System.IO.Path]::GetTempFileName())</_TempFilePath>
        </PropertyGroup>
        <DownloadFile SourceUrl="$(BgeMicroVocabUrl)"
                      DestinationFolder="$([System.IO.Path]::GetDirectoryName($(_TempFilePath)))"
                      DestinationFileName="$([System.IO.Path]::GetFileName($(_TempFilePath)))" />
        <Move SourceFiles="$(_TempFilePath)" DestinationFiles="$(BgeMicroVocabPath)"
              ContinueOnError="WarnAndContinue"
              Condition="!Exists('$(BgeMicroVocabPath)')" />
        <Delete Files="$(_TempFilePath)" Condition="Exists('$(_TempFilePath)')" />
    </Target>
</Project>
